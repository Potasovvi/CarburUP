{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/$1" },
    { "src": "/infoutili", "dest": "/infoutili.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
